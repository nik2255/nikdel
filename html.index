<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Website</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #121212;
            color: white;
        }

        header {
            background: #1f1f1f;
            padding: 20px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
        }

        .hero {
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .hero h1 {
            font-size: 3rem;
        }

        .hero p {
            margin: 15px 0;
            font-size: 1.2rem;
        }

        button {
            padding: 12px 24px;
            font-size: 16px;
            cursor: pointer;
            border: none;
            border-radius: 6px;
            background: #0078ff;
            color: white;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #1f1f1f;
        }
    </style>
</head>
<body>

<header>
    <h2>My Website</h2>
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Projects</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h1>Welcome</h1>
    <p>This is the starting page for your website.</p>
    <button onclick="alert('Hello!')">Get Started</button>
</section>

<footer>
    <p>&copy; 2026 My Website</p>
</footer>

</body>
</html>